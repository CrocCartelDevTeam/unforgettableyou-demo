# =========================================================
# Unforgettable You — environment variable template
# Copy to ".env" (gitignored) and fill in real values, then
# set the same variables in Vercel (Settings -> Environment Variables).
# Generate UY_SESSION_SECRET:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Generate a user for UY_USERS: node tools/make-user.mjs <user> <email> <password>
# =========================================================

# --- Required ---
UY_SESSION_SECRET=
UY_GH_REPO=owner/name
UY_GH_BRANCH=main
UY_GH_TOKEN=
UY_USERS=[{"username":"racheli","email":"...","salt":"...","hash":"..."},{"username":"zvika","email":"...","salt":"...","hash":"..."}]

# --- Optional ---
UY_SITE_URL=https://unforgettableyou.com
UY_RESEND_API_KEY=
UY_EMAIL_FROM=Unforgettable You <onboarding@resend.dev>
